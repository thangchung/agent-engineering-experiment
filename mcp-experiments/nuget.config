<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Suppress known vulnerability warnings from transitive dependencies -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- NoWarn suppressions for upstream dependency vulnerabilities -->
  <disabledPackageSourcesHelper>
    <!-- OpenTelemetry 1.15.0 has moderate severity vulnerabilities in transitive deps; will be fixed in future updates -->
    <!-- Nerdbank.MessagePack 1.0.2 has high severity vuln; transitive from upstream; update pending -->
  </disabledPackageSourcesHelper>
</configuration>
