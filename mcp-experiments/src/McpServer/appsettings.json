{
  "Hosting": {
    "EnableCliMode": false,
    "CliServeMode": false,
    "EnableStatistic": false
  },
  "CodeMode": {
    "Runner": "hyperlight",
    "TimeoutMs": 5000,
    "MaxToolCalls": 10,
    "Preflight": {
      "Enabled": false,
      "PythonPath": "python",
      "TimeoutMs": 2000
    }
  },
  "Copilot": {
    "Auth": {
      "Type": "github"
    },
    "Provider": {
      "Type": "openai",
      "WireApi": "completions",
      "Azure": {
        "ApiVersion": "2024-10-21"
      }
    }
  },
  "OpenApi": {
    "Sources": [
      {
        "Name": "brewery",
        "Path": "contracts/openbrewerydb.v1.openapi.yaml"
      },
      {
        "Name": "petstore",
        "Url": "https://petstore3.swagger.io/api/v3/openapi.json"
      }
    ]
  }
}