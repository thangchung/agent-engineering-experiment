@page "/"
@page "/chat"
@inject TestWeb.Services.CopilotChatApiClient ChatService
@using Markdig
@using System.Text.Json

<PageTitle>Copilot Chat</PageTitle>

<h1>Copilot Chat (Tool Search + Code Mode)</h1>
<p>Use this chat to exercise MCP tools through GitHub Copilot SDK.</p>

<div class="chat-samples mb-3">
    <div class="fw-semibold mb-2">Sample prompts</div>
    <ul class="mb-0">
        <li><strong>Discovery:</strong> what tools are available? <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "what tools are available?"'>Use</button></li>
        <li><strong>Search:</strong> show me tools for brewery filtering by city <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "show me tools for brewery filtering by city"'>Use</button></li>
        <li><strong>Schema (Concise):</strong> show concise parameter schema for getSingleBrewery and listBreweries <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "show concise parameter schema for getSingleBrewery and listBreweries"'>Use</button></li>
        <li><strong>Schema (Full):</strong> show full json schema for brewery_random <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "show full json schema for brewery_random"'>Use</button></li>
        <li><strong>Single Call:</strong> get random brewery <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "get random brewery"'>Use</button></li>
        <li><strong>Multi-step:</strong> find breweries in San Diego and return only their names and types <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "find breweries in San Diego and return only their names and types"'>Use</button></li>
        <li><strong>Aggregation:</strong> how many breweries are there across all pages <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "how many breweries are there across all pages"'>Use</button></li>
        <li><strong>Filtering:</strong> find breweries with 'moon' in the name, return top 5 as name and city <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "find breweries with moon in the name, return top 5 as name and city"'>Use</button></li>
        <li><strong>Error Handling:</strong> try calling getSingleBrewery with an invalid ID and explain the error <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "try calling getSingleBrewery with an invalid ID and explain the error"'>Use</button></li>
        <li><strong>Summary:</strong> summarize all successful brewery queries and list the tools used with token counts <button class="btn btn-sm btn-outline-secondary ms-1" @onclick='() => promptText = "summarize all successful brewery queries and list the tools used with token counts"'>Use</button></li>
        <li>
            <strong>Complex code mode:</strong>
            <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => promptText = ComplexCodeModePrompt">Use</button>
            <pre class="sample-pre">@ComplexCodeModePrompt</pre>
        </li>
    </ul>
</div>

<div class="chat-layout">
    <div class="chat-actions mb-3">
        <button class="btn btn-outline-secondary" @onclick="ResetSessionAsync" disabled="@isSending">Reset Session</button>
    </div>

    <div class="chat-log mb-3">
        <p class="text-muted mb-2">@statusText</p>

        @if (messages.Count > 0)
        {
            @foreach (ChatLine line in messages)
            {
                <div class="chat-line @(line.Role == "user" ? "chat-user" : "chat-assistant")">
                    <div class="chat-role">@line.RoleLabel</div>
                    @if (line.Metrics is not null)
                    {
                        <div class="text-muted small mb-1">
                            prompt @line.Metrics.PromptTokens tok, completion @line.Metrics.CompletionTokens tok, total @line.Metrics.TotalTokens tok, @line.Metrics.ElapsedMilliseconds ms
                        </div>
                    }
                    @if (line.Role == "assistant")
                    {
                        @if (line.ExecuteToolResult is JsonElement executeToolResult)
                        {
                            <div class="chat-content chat-structured">
                                <StructuredJsonView Value="executeToolResult" />
                            </div>
                        }
                        else
                        {
                            <div class="chat-content markdown-content">@((MarkupString)RenderMarkdown(line.Content))</div>
                        }
                    }
                    else
                    {
                        <div class="chat-content">@line.Content</div>
                    }
                </div>
            }
        }
    </div>

    <div class="chat-compose">
        <textarea class="form-control mb-2"
                  rows="4"
                  placeholder="Type your prompt here..."
                  @bind="promptText"></textarea>
        <button class="btn btn-primary send-button" @onclick="SendAsync" disabled="@isSending">
            @if (isSending)
            {
                <span class="sending-state" aria-live="polite">
                    <span class="sending-spinner" aria-hidden="true"></span>
                    <span class="sending-text">Sending<span class="sending-dots"></span></span>
                </span>
            }
            else
            {
                <span>Send</span>
            }
        </button>
    </div>
</div>

@code {
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .DisableHtml()
        .UsePipeTables()
        .UseEmphasisExtras()
        .Build();

    private readonly List<ChatLine> messages = [];
    private string promptText = string.Empty;
    private string statusText = "Send a message to start.";
    private bool isSending;

    private static string RenderMarkdown(string content)
    {
        return Markdown.ToHtml(content ?? string.Empty, MarkdownPipeline);
    }

    private async Task SendAsync()
    {
        if (isSending || string.IsNullOrWhiteSpace(promptText))
        {
            return;
        }

        string userPrompt = promptText.Trim();
        promptText = string.Empty;

        messages.Add(new ChatLine("user", "You", userPrompt));

        isSending = true;
        var stopwatch = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            TestWeb.Services.CopilotChatApiClient.ChatTurnMetrics turn = await ChatService.SendPromptAsync(userPrompt);
            stopwatch.Stop();
            messages.Add(new ChatLine(
                "assistant",
                "Assistant",
                turn.Content,
                new TurnMetrics(turn.PromptTokens, turn.CompletionTokens, turn.TotalTokens, turn.ElapsedMilliseconds),
                turn.ExecuteToolResult));
            statusText = $"Last turn: prompt {turn.PromptTokens} tok, completion {turn.CompletionTokens} tok, total {turn.TotalTokens} tok, {turn.ElapsedMilliseconds} ms.";
        }
        catch (Exception ex)
        {
            stopwatch.Stop();
            messages.Add(new ChatLine("assistant", "Assistant (error)", ex.Message));
            statusText = $"Last turn failed after {stopwatch.ElapsedMilliseconds} ms. Metrics are unavailable because the request did not complete successfully.";
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task ResetSessionAsync()
    {
        if (isSending)
        {
            return;
        }

        await ChatService.ResetAsync();
        messages.Clear();
        statusText = "Send a message to start.";
    }

    private sealed record TurnMetrics(int PromptTokens, int CompletionTokens, int TotalTokens, long ElapsedMilliseconds);

    private sealed record ChatLine(string Role, string RoleLabel, string Content, TurnMetrics? Metrics = null, JsonElement? ExecuteToolResult = null);

    private const string ComplexCodeModePrompt =
        """
        Write Python code for execute mode.

        Requirements:
        1) Get breweries in San Diego.
        2) Return the total number of breweries found for San Diego.
        3) Search for breweries matching "moon" and return top 5 with only:
           - name
           - city
        4) Also compute a San Diego summary:
           - count by brewery_type
           - top 3 cities by number of breweries (if city is missing, use "Unknown")
        5) Deduplicate breweries by id before counting.
        6) Sort outputs deterministically:
           - type summary: count desc, then type asc
           - top cities: count desc, then city asc
           - moon top 5: name asc
        7) Return one JSON object in `result` with this exact shape:
        {
          "san_diego_total": number,
          "san_diego_type_summary": [{"brewery_type": string, "count": number}],
          "san_diego_top_cities": [{"city": string, "count": number}],
          "moon_top_5": [{"name": string, "city": string}]
        }
        8) If any tool call fails, set a top-level "errors" array with readable messages but still return partial data.
        """;
}
